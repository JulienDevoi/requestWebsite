# Environment Variables Example
# Copy this file to .env.local and fill in your actual values

# Weglot API Key for translation services
NEXT_PUBLIC_WEGLOT_API_KEY=your_weglot_api_key_here

# Beam Analytics Token
NEXT_PUBLIC_BEAM_ANALYTICS_TOKEN=your_beam_analytics_token_here

# Webhook secret — used by /api/webhooks/signup to reject unauthenticated callers
# Generate with: openssl rand -base64 32
WEBHOOK_SIGNUP_SECRET=your_webhook_signup_secret_here

# Upstash Redis — enables distributed (cross-instance) rate limiting in middleware
# Create a free database at https://console.upstash.com
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token_here

# Site URL (optional, defaults to https://requestfinance.com)
# NEXT_PUBLIC_SITE_URL=https://requestfinance.com
